<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<title>Project Management</title>

<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{

    background:#071b3b;

    min-height:100vh;

    color:#fff;

    overflow-x:hidden;

    padding:20px;

    position:relative;
}

/* Background */

body::before{

    content:'';

    position:fixed;

    inset:0;

    background:
    linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px);

    background-size:80px 40px;

    z-index:-1;
}

/* Container */

.container{

    max-width:1200px;

    margin:auto;
}

/* Header */

.header{

    display:flex;

    justify-content:space-between;

    align-items:center;

    margin-bottom:40px;

    gap:20px;

    flex-wrap:wrap;
}

.header h1{

    font-size:42px;

    font-weight:700;
}

/* Button */

.create-btn{

    padding:14px 28px;

    border-radius:40px;

    background:#fff;

    color:#111;

    font-size:16px;

    font-weight:600;

    transition:0.3s;

    text-decoration:none;

    display:flex;

    align-items:center;

    gap:10px;
}

.create-btn:hover{

    transform:translateY(-3px);

    background:#ececec;
}

/* Project Grid */

.project-grid{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));

    gap:25px;
}

/* Card */

.project-card{

    background:rgba(255,255,255,0.08);

    border:1px solid rgba(255,255,255,0.12);

    backdrop-filter:blur(12px);

    border-radius:25px;

    padding:25px;

    transition:0.3s;

    overflow:hidden;

    position:relative;
}

.project-card:hover{

    transform:translateY(-5px);

    background:rgba(255,255,255,0.1);
}

/* Glow */

.project-card::before{

    content:'';

    position:absolute;

    width:180px;
    height:180px;

    background:rgba(255,255,255,0.05);

    border-radius:50%;

    top:-90px;
    right:-90px;
}

/* Icon */

.icon{

    width:70px;
    height:70px;

    border-radius:50%;

    background:rgba(255,255,255,0.08);

    display:flex;

    justify-content:center;

    align-items:center;

    margin-bottom:20px;

    border:1px solid rgba(255,255,255,0.12);
}

.icon i{

    font-size:30px;
}

/* Text */

.project-card h2{

    font-size:26px;

    margin-bottom:14px;

    word-break:break-word;
}

.project-card p{

    color:#ddd;

    line-height:1.8;

    margin-bottom:12px;

    word-break:break-word;
}

/* Priority */

.priority{

    display:inline-block;

    margin-top:12px;

    padding:8px 16px;

    border-radius:30px;

    background:#fff;

    color:#111;

    font-size:14px;

    font-weight:600;
}

/* Empty */

.empty{

    text-align:center;

    padding:80px 20px;

    background:rgba(255,255,255,0.06);

    border-radius:25px;
}

.empty h2{

    margin-bottom:15px;
}

/* Mobile */

@media(max-width:768px){

    body{

        padding:15px;
    }

    .header{

        flex-direction:column;

        align-items:flex-start;
    }

    .header h1{

        font-size:34px;
    }

    .create-btn{

        width:100%;

        justify-content:center;
    }

    .project-grid{

        grid-template-columns:1fr;
    }

    .project-card{

        padding:20px;
    }

    .project-card h2{

        font-size:22px;
    }

    .icon{

        width:60px;
        height:60px;
    }

    .icon i{

        font-size:26px;
    }

}
.member-section{

    margin-top:25px;
}

.member-section h3{

    margin-bottom:15px;
}

.member-box{

    background:rgba(255,255,255,0.08);

    border:1px solid rgba(255,255,255,0.1);

    padding:12px 15px;

    border-radius:14px;

    margin-bottom:12px;

    display:flex;

    justify-content:space-between;

    align-items:center;

    gap:10px;

    flex-wrap:wrap;
}

.member-form{

    margin-top:20px;
}

.member-form input{

    width:100%;

    padding:14px;

    border:none;

    border-radius:14px;

    margin-bottom:12px;

    outline:none;
}

.member-form button{

    width:100%;

    padding:14px;

    border:none;

    border-radius:14px;

    background:#fff;

    color:#111;

    font-weight:600;

    cursor:pointer;
}

.remove-btn{

    width:42px;
    height:42px;

    border:none;

    border-radius:50%;

    background:#ff4d4d;

    color:#fff;

    cursor:pointer;
}

.top-buttons{

    display:flex;

    gap:15px;

    align-items:center;
}

.dashboard-btn{

    padding:14px 28px;

    border-radius:40px;

    background:#ffffff1a;

    color:#fff;

    font-size:16px;

    font-weight:600;

    transition:0.3s;

    text-decoration:none;

    display:flex;

    align-items:center;

    gap:10px;

    border:1px solid rgba(255,255,255,0.1);
}

.dashboard-btn:hover{

    transform:translateY(-3px);

    background:#ffffff2a;
}
@media(max-width:768px){

    body{

        padding:15px;
    }

    .header{

        flex-direction:column;

        align-items:flex-start;
    }

    .header h1{

        font-size:34px;
    }

    .top-buttons{

        width:100%;

        flex-direction:column;
    }

    .dashboard-btn,
    .create-btn{

        width:100%;

        justify-content:center;
    }

    .project-grid{

        grid-template-columns:1fr;
    }

}


</style>

</head>

<body>

<div class="container">

    <!-- Header -->

    <div class="header">

        <h1>Project Management</h1>
        <a
href="/dashboard"
class="dashboard-btn">

    <i class="fa-solid fa-house"></i>

    Back To Dashboard

</a>
        <a
        href="/create-project"
        class="create-btn">

            <i class="fa-solid fa-plus"></i>

            Create Project

        </a>

    </div>

    <!-- Projects -->

    <% if(projects.length > 0){ %>

        <div class="project-grid">

            <% projects.forEach(project => { %>

                <div class="project-card">

                    <div class="icon">

                        <i class="fa-solid fa-folder-open"></i>

                    </div>

                    <h2>

                        <%= project.title %>

                    </h2>

                    <p>

                        <%= project.description %>

                    </p>

                    <p>

                        <strong>Due:</strong>

                        <%= project.dueDate.toDateString() %>

                    </p>

                    <div class="priority">

    <%= project.priority %>

</div>

<!-- Members -->

<div class="member-section">

    <h3>

        Members

    </h3>

    <% if(project.members.length > 0){ %>

        <% project.members.forEach(member => { %>

            <div class="member-box">

                <div>

                    <strong>

                        <%= member.name %>

                    </strong>

                    <br>

                    <small>

                        <%= member.email %>

                    </small>

                </div>

                <form
                action="/remove-member"
                method="POST">

                    <input
                    type="hidden"
                    name="projectid"
                    value="<%= project._id %>">

                    <input
                    type="hidden"
                    name="email"
                    value="<%= member.email %>">

                    <button
                    type="submit"
                    class="remove-btn">

                        <i class="fa-solid fa-trash"></i>

                    </button>

                </form>

            </div>

        <% }) %>

    <% } %>

</div>

<!-- Add Member -->

<form
action="/add-member"
method="POST"
class="member-form">

    <input
    type="hidden"
    name="projectid"
    value="<%= project._id %>">

    <input
    type="email"
    name="email"
    placeholder="Enter Member Email"
    required>

    <button type="submit">

        Add Member

    </button>

</form>

                </div>

            <% }) %>

        </div>

        

    <% } else { %>

        <div class="empty">

            <h2>No Projects Found</h2>

            <p>Create your first project</p>

        </div>

    <% } %>

</div>

</body>

</html>